# syntax=docker/dockerfile:1
# Multi-stage build — финальный образ содержит только production-зависимости
# и скомпилированный dist/, без dev-инструментов (tsx, typescript, eslint).

FROM node:20-alpine AS deps
WORKDIR /app
COPY package*.json ./
RUN npm ci --include=dev

FROM node:20-alpine AS build
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
RUN npm run build

FROM node:20-alpine AS runtime
WORKDIR /app
ENV NODE_ENV=production
COPY package*.json ./
RUN npm ci --omit=dev && npm cache clean --force
COPY --from=build /app/dist ./dist

# Не запускаем контейнер от root'а — стандартная практика для Node-образов.
USER node
EXPOSE 3000
CMD ["node", "dist/server.js"]
