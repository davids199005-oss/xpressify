import express, { type Request, type Response, type NextFunction } from 'express';
import cors from 'cors';
import helmet from 'helmet';
import { rateLimit } from 'express-rate-limit';

const app = express();

// Express 5 automatically forwards rejected promises from async handlers to
// the error middleware at the bottom of this file — no need for try/catch
// in route handlers and no need for express-async-errors.

// Remove the X-Powered-By header. Helmet also does this, but setting it
// explicitly means the behavior doesn't depend on middleware order.
app.disable('x-powered-by');

// ─── Trust proxy ────────────────────────────────────────────────────────────
// If the app runs behind a reverse proxy (Nginx, Cloudflare, Railway, Fly,
// Heroku), you MUST enable this. Otherwise express-rate-limit sees every
// request as coming from the proxy IP and the limiter becomes useless.
// Set to a specific number of proxy hops or a subnet list — do NOT set it
// to `true` in production, that trusts any X-Forwarded-For header and lets
// attackers bypass rate limiting by spoofing IPs.
// Docs: https://expressjs.com/en/guide/behind-proxies.html
// app.set('trust proxy', 1);

// ─── Security headers ──────────────────────────────────────────────────────
app.use(helmet());

// ─── CORS ──────────────────────────────────────────────────────────────────
// Origins are read from the CORS_ORIGIN env var (comma-separated).
// If the variable is not set, CORS is disabled entirely — the API refuses
// all cross-origin requests from browsers. This is a safe default for APIs
// that aren't meant to be called from the browser at all.
// Example .env: CORS_ORIGIN=https://app.example.com,https://admin.example.com
const corsOrigins = process.env['CORS_ORIGIN']
  ?.split(',')
  .map((o) => o.trim())
  .filter(Boolean);

app.use(
  cors({
    origin: corsOrigins && corsOrigins.length > 0 ? corsOrigins : false,
    credentials: true,
  }),
);

// ─── Body parsers ──────────────────────────────────────────────────────────
// Keep the limit tight — anything larger is almost always a file upload
// that should go through multipart/form-data (multer, busboy) or object
// storage, not straight into JSON.
app.use(express.json({ limit: '100kb' }));
app.use(express.urlencoded({ extended: true, limit: '100kb' }));

// ─── Rate limiting ─────────────────────────────────────────────────────────
// In-memory store is fine for a single-instance deploy. For multi-instance
// (k8s, fly multi-region, pm2 cluster) you need a shared backend, e.g.
// https://github.com/express-rate-limit/rate-limit-redis
app.use(
  rateLimit({
    windowMs: 15 * 60 * 1000, // 15 minutes
    limit: 100, // each IP: 100 requests per window
    standardHeaders: 'draft-8', // combined RateLimit header (IETF draft-8)
    legacyHeaders: false, // remove legacy X-RateLimit-* headers
    ipv6Subnet: 56, // group IPv6 addresses by /56 subnet
  }),
);

// ─── Routes ────────────────────────────────────────────────────────────────
app.get('/health', (_req, res) => {
  res.json({ status: 'ok' });
});

// ─── 404 handler ───────────────────────────────────────────────────────────
// Any request not matched by the routes above lands here.
app.use((_req, res) => {
  res.status(404).json({ message: 'Not Found' });
});

// ─── Error handler ─────────────────────────────────────────────────────────
// Express recognizes an error handler by its 4-argument signature.
// In production, don't leak err.stack to the client — it exposes internals.
// eslint-disable-next-line @typescript-eslint/no-unused-vars
app.use((err: Error, _req: Request, res: Response, _next: NextFunction) => {
  // eslint-disable-next-line no-console
  console.error(err);
  res.status(500).json({ message: 'Internal Server Error' });
});

export default app;
